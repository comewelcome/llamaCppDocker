# ============================================================
# Configuration Llama.cpp Server - VRAM ONLY (zéro RAM)
# ============================================================

MODEL=/models/Qwen3.6-27B-UD-Q4_K_XL.gguf #Qwopus3.6-27B-Coder-MTP-Q5_K_M.gguf
MMPROJ=/models/mmproj-BF16.gguf

# Force la haute définition pour ne pas perdre les écritures du plan 300 DPI
IMAGE_MIN_TOKENS=4
IMAGE_MAX_TOKENS=2048

# Contexte - réduit pour garder tout en VRAM
CTX_SIZE=262144
GPU_LAYERS=99
THREADS=12
BATCH_SIZE=8192
PARALLEL=1
FLASH_ATTENTION=1

# Répartition Multi-GPU
TENSOR_SPLIT=1,1
SPLIT_MODE=row

# Activation de la réflexion
REASONING=on
REASONING_BUDGET=8192

# Cache KV - Q8 au lieu de f16 pour économiser 50% de VRAM
KV_UNIFIED=1
CACHE_TYPE_K=f16 #q8_0
CACHE_TYPE_V=f16 #q8_0
CACHE_RAM=24576

# Décodage Spéculatif MTP
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
SPEC_DRAFT_P_MIN=0.0

# Paramètres orientés Précision / Factuel
LLAMA_TEMP=0.6
TOP_K=20
TOP_P=0.95
REPEAT_PENALTY=1.00
PRESENCE_PENALTY=1.5

PORT=1234
LLAMA_MODELS=./models
LLAMA_CACHE=./cache

# Checkpoints contexte
CTX_CHECKPOINT_N=128
