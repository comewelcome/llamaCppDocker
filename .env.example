# HuggingFace repository (format: owner/repo)
HF_REPO=

# Context size in tokens
CTX_SIZE=262144

# Number of layers offloaded to GPU (999 = all)
GPU_LAYERS=99

# CPU threads
THREADS=6

# Batch size for evaluation
BATCH_SIZE=512

# Number of parallel requests
PARALLEL=1

# Multi-GPU tensor split (e.g., 0.75,0.25 for 2 GPUs)
TENSOR_SPLIT=0.75,0.25

# Host port
PORT=1234

# Model cache directory (mounted as ./modele)
LLAMA_CACHE=/app/modele