# ============================================================
# Configuration Llama.cpp Server
# ============================================================

# --------------------------------------------------
# Modèle et HuggingFace
# --------------------------------------------------
# Repository HuggingFace au format owner/repo:filename (ex: unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q5_K_XL)
HF_REPO=unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q4_K_XL

# Chemin du projecteur multimodal pour les modèles vision (optionnel, relatif à /app/modele)
# Exemple: models--unsloth--Qwen3.6-27B-MTP-GGUF/snapshots/xxx/mmproj-BF16.gguf
# Laisser vide si le modèle n'est pas multimodal
MMPROJ=
# --------------------------------------------------
# Contexte et performance
# --------------------------------------------------
# Taille du contexte en tokens (262144 = 256k, réduire si manque de VRAM)
CTX_SIZE=262144

# Nombre de couches offloadées sur GPU (99 = presque tout, 0 = CPU uniquement)
GPU_LAYERS=99

# Nombre de threads CPU pour l'inférence
THREADS=12

# Taille du batch pour l'évaluation (plus grand = plus rapide mais plus de VRAM)
BATCH_SIZE=512

# Nombre de requêtes parallèles gérées simultanément
PARALLEL=1

# --------------------------------------------------
# GPU et mémoire
# --------------------------------------------------
# Répartition multi-GPU (ex: 0.80,0.20 pour 2 GPU, ou 1 pour GPU unique)
TENSOR_SPLIT=0.80,0.20

# --------------------------------------------------
# Cache KV
# --------------------------------------------------
# Type de quantification du cache key (q4_0, q8_0, f16, f32)
# q4_0 réduit la mémoire, f16 pour la précision maximale
CACHE_TYPE_K=q8_0

# Type de quantification du cache value (q4_0, q8_0, f16, f32)
CACHE_TYPE_V=q8_0

# --------------------------------------------------
# Décodage spéculatif MTP
# --------------------------------------------------
# Type de décodage spéculatif (draft-mtp pour Multi-Token Prediction)
SPEC_TYPE=draft-mtp

# Nombre maximum de tokens prédits par le modèle de draft
SPEC_DRAFT_N_MAX=2

# Seuil minimum de probabilité pour accepter les tokens draft (0.0 à 1.0)
SPEC_DRAFT_P_MIN=0.0

# --------------------------------------------------
# Flash Attention
# --------------------------------------------------
# Activer Flash Attention pour un calcul plus rapide et moins de mémoire (on/off)
FLASH_ATTENTION=on

# --------------------------------------------------
# Paramètres de génération
# --------------------------------------------------
# Température d'échantillonnage (0 = déterministe, plus élevé = plus créatif)
TEMP=0.6

# Top-k : nombre maximum de tokens considérés pour chaque prédiction
TOP_K=20

# Top-p : seuil de probabilité cumulée pour l'échantillonnage (0.0 à 1.0)
TOP_P=0.95

# Pénalité de répétition (> 1 réduit la répétition, 1 = désactivé)
REPEAT_PENALTY=1.00
PRESENCE_PENALTY=1.5

# --------------------------------------------------
# Réseau et serveur
# --------------------------------------------------
# Port exposé sur l'hôte
PORT=1234

# --------------------------------------------------
# Stockage
# --------------------------------------------------
# Répertoire de cache des modèles (monté comme ./modele)
LLAMA_MODELS=./models
LLAMA_CACHE=./cache