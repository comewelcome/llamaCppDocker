# ============================================================
# Configuration Llama.cpp Server (Optimisée Plans & VLM 2026)
# ============================================================

MODEL=/models/Qwen3.6-27B-UD-Q5_K_XL.gguf
MMPROJ=/models/mmproj-BF16.gguf

# Force la haute définition pour ne pas perdre les écritures du plan 300 DPI
IMAGE_MIN_TOKENS=4
IMAGE_MAX_TOKENS=2048
# Contexte réaliste pour éviter les crashs VRAM (OOM) avec le cache Q8
CTX_SIZE=262144
GPU_LAYERS=-1
THREADS=12
BATCH_SIZE=2048
PARALLEL=1
FLASH_ATTENTION=1

# Répartition Multi-GPU (Ajuster selon votre second GPU)
TENSOR_SPLIT=0,0

# Activation indispensable de la réflexion pour l'analyse spatiale
REASONING=on
REASONING_BUDGET=8192

# Cache KV de haute précision
KV_UNIFIED=1
CACHE_TYPE_K=f16
CACHE_TYPE_V=f16

# Décodage Spéculatif MTP (À passer à 'none' en cas de crash avec l'image)
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
SPEC_DRAFT_P_MIN=0.0

# Paramètres orientés Précision / Factuel
TEMP=0.6
TOP_K=20
TOP_P=0.95
REPEAT_PENALTY=1.00
PRESENCE_PENALTY=1.5

PORT=1234
LLAMA_MODELS=./models
LLAMA_CACHE=./cache