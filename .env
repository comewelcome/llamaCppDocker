# ============================================================
# Configuration Llama.cpp Server - VRAM ONLY (zéro RAM)
# ============================================================

MODEL=/models/Qwopus3.6-35B-A3B-Coder-MTP-Q5_K_M.gguf
MMPROJ=

# Force la haute définition pour ne pas perdre les écritures du plan 300 DPI
IMAGE_MIN_TOKENS=4
IMAGE_MAX_TOKENS=2048

# Contexte - réduit pour garder tout en VRAM
CTX_SIZE=262144
GPU_LAYERS=-1
NGL=999
THREADS=12
BATCH_SIZE=8192
PARALLEL=6
FLASH_ATTENTION=1

# Répartition Multi-GPU
TENSOR_SPLIT=1,1

# Activation de la réflexion
REASONING=on
REASONING_BUDGET=8192

# Cache KV - Q8 au lieu de f16 pour économiser 50% de VRAM
KV_UNIFIED=1
CACHE_TYPE_K=f16
CACHE_TYPE_V=f16

# Décodage Spéculatif MTP
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=6
SPEC_DRAFT_N_MIN=0
SPEC_DRAFT_P_MIN=0.75

# Paramètres orientés Précision / Factuel
LLAMA_TEMP=0.6
TOP_K=20
TOP_P=0.95
REPEAT_PENALTY=1.00
PRESENCE_PENALTY=1.5

PORT=1234
LLAMA_MODELS=./models
LLAMA_CACHE=./cache

# Checkpoints contexte
CTX_CHECKPOINT_N=4
