# ============================================================
# Configuration Llama.cpp Server (Optimisée 2026)
# ============================================================

# --------------------------------------------------
# Modèle, Vision et HuggingFace
# --------------------------------------------------
MODEL=/models/Qwen3.6-27B-UD-Q4_K_XL.gguf
MMPROJ=/models/mmproj-BF16.gguf

# Fixe l'alignement des objets pour Qwen-VL et accélère la détection
IMAGE_MIN_TOKENS=1024

# --------------------------------------------------
# Contexte et Performance (Ajusté pour RTX 3090 24 Go)
# --------------------------------------------------
# 64k est idéal pour ne pas saturer la VRAM avec les images de Qwen-VL
CTX_SIZE=100000

# Ajusté pour laisser de la place au traitement multimodal et au Speculative Decoding
GPU_LAYERS=99
THREADS=12
BATCH_SIZE=512
PARALLEL=1

# Activer Flash Attention (1 = Oui, 0 = Non)
FLASH_ATTENTION=1

# --------------------------------------------------
# Désactivation Totale du Mode Réflexion (Thinking / Reasoning)
# --------------------------------------------------
# Force le budget de tokens de réflexion à 0 (Désactive le bloc <think>)
REASONING_BUDGET=0

# --------------------------------------------------
# Cache KV & Unified Memory
# --------------------------------------------------
# Active l'unification du cache pour éviter les expulsions ("erased invalidated context")
KV_UNIFIED=1

# Types de cache (f16 est recommandé avec Flash Attention pour éviter les bugs d'attention de Qwen)
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q4_0

# --------------------------------------------------
# Décodage Spéculatif MTP
# --------------------------------------------------
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
SPEC_DRAFT_P_MIN=0.0

# --------------------------------------------------
# Paramètres de Génération (Sans interférence de réflexion)
# --------------------------------------------------
TEMP=0.6
TOP_K=20
TOP_P=0.95
REPEAT_PENALTY=1.00
PRESENCE_PENALTY=1.5

# --------------------------------------------------
# Réseau et Serveur
# --------------------------------------------------
PORT=1234

# --------------------------------------------------
# Stockage
# --------------------------------------------------
LLAMA_MODELS=./models
LLAMA_CACHE=./cache