# ============================================================
# Configuration Llama.cpp Server - Ornith-1.0-35B MoE (Q6_K)
# ============================================================

# Modèle cible (Q6_K téléchargé dans ./models)
MODEL=/models/ornith-1.0-35b-Q6_K.gguf

# Désactivation de la vision (Ornith est un modèle pur texte/code)
MMPROJ=
IMAGE_MIN_TOKENS=0
IMAGE_MAX_TOKENS=0

# --- CONTEXTE ET MULTI-GPU ---
# 64k contexte - bon équilibre pour 48 Go VRAM (2x RTX 3090)
CTX_SIZE=262144
GPU_LAYERS=-1
THREADS=12

# Batch size 2048 - réglé pour éviter les OOM avec les experts MoE
BATCH_SIZE=2048
PARALLEL=1
FLASH_ATTENTION=1

# Répartition Multi-GPU (2x RTX 3090 en tensor split égal)
TENSOR_SPLIT=1,1

# --- CONFIGURATION DU CACHE KV ---
# Cache unifié + q8_0 pour économiser la VRAM
KV_UNIFIED=1
CACHE_TYPE_K=f16 #q8_0
CACHE_TYPE_V=f16 #q8_0

# --- RAISONNEMENT / CHAIN OF THOUGHT ---
# Active le mode pensée pour les balises rix du modèle Ornith
REASONING=on
REASONING_FORMAT=deepseek
REASONING_BUDGET=4096

# --- DÉCODAGE SPÉCULATIF (Désactivé) ---
# Ornith n'utilise pas de draft model par défaut
SPEC_TYPE=none
SPEC_DRAFT_N_MAX=0
SPEC_DRAFT_N_MIN=0
SPEC_DRAFT_P_MIN=0.0

# --- HYPERPARAMÈTRES OFFICIELS (Code / RL Agent) ---
LLAMA_TEMP=0.6
TOP_K=20
TOP_P=0.95
REPEAT_PENALTY=1.00
PRESENCE_PENALTY=0.0

# --- INFRASTRUCTURE ---
PORT=1234
LLAMA_MODELS=./models
LLAMA_CACHE=./cache
CTX_CHECKPOINT_N=4
